# Copy to backend/.env for local dev, or set these in the host dashboard for deploy.
# The real backend/.env is gitignored — never commit secrets.

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017        # Atlas SRV URI in production
MONGO_DB=pl_injury

# --- API-Football (Pro plan) ---
API_FOOTBALL_KEY=your_key_here
API_FOOTBALL_HOST=v3.football.api-sports.io
LEAGUE_ID=39
INGEST_SEASONS=2022,2023,2024,2025
REQ_PER_MIN=250
MAX_FIXTURE_DETAIL=380
MAX_EURO_DETAIL=200
MAX_INTL_DETAIL=150

# --- App ---
DATA_SOURCE=apifootball
AUTH_SECRET=change_me_to_a_long_random_string
APP_URL=http://localhost:5173              # your Vercel URL in production

# --- Email (Brevo SMTP) — optional; falls back to backend/outbox/ ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Workload IQ <you@yourdomain.com>
